# LLM provider credentials
OPENAI_API_KEY=sk-xxx

# OpenAI-compatible API endpoint
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Default model
MODEL=anthropic/claude-sonnet-4

# Runtime profile directory
HERMES_HOME=.hermes

# Optional fallback provider
FALLBACK_MODEL=
FALLBACK_BASE_URL=
FALLBACK_API_KEY=
